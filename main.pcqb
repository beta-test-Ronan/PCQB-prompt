def PCQB(query, parameters, context):

    state = initialize(query, parameters, context)

    stages = [
        IntentExtraction,
        ConstraintMapping,
        HypothesisGeneration,
        ConflictDetection,
        ResponseSynthesis
    ]

    for stage in stages:
        state = execute(stage, state)
        trace = bounded_record(state)

    return synthesize(state, trace)
[/pcqb-regra]

